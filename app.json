{
  "expo": {
    "name": "synchme",
    "slug": "synchme",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "LSApplicationQueriesSchemes": [
          "App-Prefs"
        ],
        "NSLocalNetworkUsageDescription": "App requires local network access to find other Ableton Link devices.",
        "NSBonjourServices": [
          "_ableton-link._udp",
          "_ableton-link._tcp"
        ]
      },
      "bundleIdentifier": "com.soyante.synchme"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "package": "com.soyante.synchme"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "munim-bluetooth",
        {
          "bluetoothBackground": true,
          "androidBluetoothPermissions": [
            "scan",
            "connect",
            "advertise"
          ],
          "bluetoothAlwaysUsageDescription": "Allow SynchMe to connect to nearby devices to sync audio playback."
        }
      ],
      "expo-build-properties",
      "expo-audio"
    ]
  }
}
